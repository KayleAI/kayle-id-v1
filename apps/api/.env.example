# Schema input for `wrangler types` — keep this list of keys in sync with the
# secrets configured in Infisical (and synced to the kayle-id-api Worker).
# Values are placeholders; the bootstrap (`bun run env:setup`) writes real
# local values to the repo-root `.env`.

NODE_ENV=
PUBLIC_VERIFY_URL=
PUBLIC_CDN_ORIGIN=
KAYLE_INTERNAL_TOKEN=
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BIOMETRIC_VERIFIER_SECRET=
ORG_VERIFICATION_PEPPER=
REDIS_URL=
REDIS_TOKEN=
VERIFY_PKD_TRUST_BUNDLE_JSON=
# App Attest gate: "true" requires every verify hello + NFC assertion to
# carry a valid Apple App Attest assertion bound to the attempt. Roll out by
# setting this to "true" only after MIN_APP_VERSION clears the partner adoption
# threshold (≥98% of last 7d hellos).
VERIFY_REQUIRE_ATTESTATION=
# Semver floor on `appVersion` reported in the verify hello. Hellos below
# this version are rejected with `MIN_APP_VERSION_REQUIRED` BEFORE the
# attestation lookup so old clients see a clean "update required" path. Leave
# blank pre-rollout.
MIN_APP_VERSION=1.3.5
# Apple App Attest receipt-refresh signing material (Apple Developer →
# Keys → "App Attest" capability). PEM-encoded P-256 PKCS#8 private key,
# its 10-char Apple key ID, and the developer team ID. Optional: when blank
# the periodic riskMetric refresh is skipped silently.
APP_ATTEST_RECEIPT_SIGNING_KEY=
APP_ATTEST_RECEIPT_SIGNING_KEY_ID=
APP_ATTEST_TEAM_ID=

# The single organization with platform-admin access (e.g. the in-app
# approvals dashboard at /admin). Hard-coded by env so it cannot be
# flipped via DB write — even with database access, an attacker would
# need worker-secret access to escalate. Optional in dev/test.
KAYLE_ORGANIZATION_ID=
