{
  "name": "kayle-id-biometric-verifier",
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev-with-healthcheck.sh",
    "deploy": "bunx wrangler deploy --minify --env production",
    "deploy:bench": "bunx wrangler deploy --minify --env bench",
    "cf:types": "bunx wrangler types --env-file .env.example --env-interface BiometricVerifierBindings cloudflare-env.d.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bunx wrangler deploy --dry-run --outdir .wrangler-out"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.0.25",
    "@kayle-id/config": "*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "22.19.1"
  }
}
