{
  "include": [
    "cloudflare-env.d.ts",
    "src/**/*.ts",
    "../../apps/api/src/types/static-assets.d.ts"
  ],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun", "node"],
    "paths": {
      "*": ["./*"],
      "@/*": ["../../apps/api/src/*"]
    }
  }
}
