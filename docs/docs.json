{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Kayle ID",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "concepts/how-it-works"]
          },
          {
            "group": "Verifications",
            "pages": [
              "verifications/sessions",
              "verifications/share-fields",
              "verifications/document-checks",
              "verifications/handoff",
              "verifications/privacy"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/configuring-endpoints",
              "webhooks/verifying-signatures",
              "webhooks/encryption",
              "webhooks/deliveries"
            ]
          },
          {
            "group": "Authentication",
            "pages": ["auth/api-keys", "auth/scopes"]
          },
          {
            "group": "Self-hosting",
            "pages": ["self-hosting/overview"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Introduction",
            "pages": ["api-reference/introduction", "api-reference/errors"]
          },
          {
            "group": "Endpoints",
            "openapi": "/api-reference/openapi.json"
          },
          {
            "group": "Webhook events",
            "pages": [
              "api-reference/webhooks/verification-attempt-succeeded",
              "api-reference/webhooks/verification-attempt-failed",
              "api-reference/webhooks/verification-session-expired",
              "api-reference/webhooks/verification-session-cancelled"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:help@kayle.id"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/KayleAI/kayle-id"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://kayle.id"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
