{
  "name": "kayle-id-biometric-verifier",
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev-with-healthcheck.sh",
    "deploy": "bunx wrangler deploy --minify --env production",
    "deploy:bench:lite": "bunx wrangler deploy --minify --env bench-lite",
    "deploy:bench:basic": "bunx wrangler deploy --minify --env bench-basic",
    "deploy:bench:standard-1": "bunx wrangler deploy --minify --env bench-standard-1",
    "deploy:bench:standard-2": "bunx wrangler deploy --minify --env bench-standard-2",
    "deploy:bench:standard-3": "bunx wrangler deploy --minify --env bench-standard-3",
    "deploy:bench:standard-4": "bunx wrangler deploy --minify --env bench-standard-4",
    "deploy:bench:standard-1-tuned": "bunx wrangler deploy --minify --env bench-standard-1-tuned",
    "deploy:bench:standard-3-tuned": "bunx wrangler deploy --minify --env bench-standard-3-tuned",
    "cf:types": "bunx wrangler types --env-file .env.example --env-interface BiometricVerifierBindings cloudflare-env.d.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bunx wrangler deploy --dry-run --outdir .wrangler-out"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.0.25",
    "@kayle-id/config": "*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "22.19.1"
  }
}
