{
  "name": "kayle-id-face-matcher",
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev-with-healthcheck.sh",
    "deploy": "bunx wrangler deploy --minify",
    "cf-typegen": "bunx wrangler types --env-file ../../.env --env-interface FaceMatcherBindings cloudflare-env.d.ts",
    "test:dev": "bunx wrangler dev --env-file ../../.env.test.example --local --ip 127.0.0.1 --port 8788",
    "test": "bun test",
    "build": "bunx wrangler deploy --dry-run --outdir .wrangler-out"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.0.25",
    "@cornerstonejs/codec-openjpeg": "1.3.0",
    "@kayle-id/config": "*",
    "jpeg-js": "0.4.4"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
