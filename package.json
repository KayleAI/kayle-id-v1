{
  "dependencies": {
    "@t3-oss/env-core": "0.13.10",
    "drizzle-orm": "1.0.0-beta.22",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@fontsource-variable/inter": "5.2.8",
    "@types/pg": "8.15.6",
    "capnp-es": "0.0.14",
    "dotenv": "17.2.3",
    "drizzle-kit": "1.0.0-beta.22",
    "husky": "9.1.7",
    "turbo": "2.6.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "ultracite": "7.6.0",
    "wrangler": "4.83.0"
  },
  "name": "kayle-id",
  "scripts": {
    "dev": "turbo run dev --filter=kayle-id-api --filter=kayle-id-face-matcher --filter=kayle-id-platform --filter=kayle-id-verify",
    "dev:seed": "bash ./scripts/seed-local-dev.sh",
    "env:setup": "bun ./scripts/setup-env.ts",
    "env:pull": "bash ./scripts/pull-env.sh",
    "test": "turbo run test",
    "prod:seed:pkd": "bash ./scripts/seed-production-pkd.sh",
    "dev:ios": "turbo run dev --filter=kayle-id-ios",
    "dev:android": "turbo run dev --filter=kayle-id-android",
    "lint": "bun run lint:format && bun run lint:runtime-logs && bun run lint:actions",
    "lint:format": "ultracite check",
    "lint:runtime-logs": "bun ./scripts/check-runtime-console.ts",
    "lint:actions": "bun ./scripts/check-github-actions-pinned.ts",
    "capnp:generate:ts": "bash ./scripts/generate-capnp-ts.sh",
    "format": "ultracite fix",
    "pkd:import": "bun ./scripts/import-icao-pkd.ts",
    "cf:types": "turbo run cf:types",
    "db:setup": "cd packages/database && bun run db:migrate && bun run db:seed",
    "db:start": "docker compose -p kayle-id -f ./infra/postgres/compose.yml up -d --remove-orphans",
    "db:stop": "docker compose -p kayle-id -f ./infra/postgres/compose.yml down --remove-orphans",
    "db:logs": "docker compose -p kayle-id -f ./infra/postgres/compose.yml logs -f",
    "db:clean": "docker compose -p kayle-id -f ./infra/postgres/compose.yml down -v --remove-orphans",
    "auth:format": "bunx ultracite fix ./packages/database/src/schema/auth.ts",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ./packages/auth/src/server.ts --output ./packages/database/src/schema/auth.ts --yes && bun run auth:format",
    "prepare": "husky",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "version": "1.3.6",
  "workspaces": [
    "apps/*",
    "infra/*",
    "packages/*"
  ],
  "description": "Privacy-first identity verification.",
  "private": true,
  "packageManager": "bun@1.3.6",
  "overrides": {
    "brace-expansion": "5.0.5",
    "defu": "6.1.7",
    "diff": "8.0.3",
    "esbuild": "^0.27.3",
    "fast-uri": "3.1.2",
    "hono": "4.12.18",
    "next": "16.2.4",
    "picomatch": "2.3.2",
    "postcss": "^8.5.10",
    "rollup": "4.60.1",
    "undici": "7.24.8",
    "uuid": "^14.0.0",
    "vite": "7.3.2",
    "yaml": "2.8.3"
  }
}
