{
  "name": "kayle-id",
  "description": "Privacy-first identity verification.",
  "version": "1.0.5",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=kayle-id-api --filter=kayle-id-face-matcher --filter=kayle-id-platform --filter=kayle-id-verify",
    "dev:ios": "turbo run dev --filter=kayle-id-ios",
    "dev:android": "turbo run dev --filter=kayle-id-android",
    "lint": "bun run lint:format && bun run lint:runtime-logs",
    "lint:format": "ultracite check",
    "lint:runtime-logs": "bun ./scripts/check-runtime-console.ts",
    "capnp:generate:ts": "bash ./scripts/generate-capnp-ts.sh",
    "format": "ultracite fix",
    "cf-typegen": "turbo run cf-typegen",
    "db:setup": "cd packages/database && bun run db:migrate && bun run db:seed",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:logs": "docker compose logs -f",
    "db:clean": "docker compose down -v && docker volume rm kayle-id_kayle-id-data",
    "auth:format": "bunx ultracite fix ./packages/database/src/schema/auth.ts",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ./packages/auth/src/server.ts --output ./packages/database/src/schema/auth.ts --yes && bun run auth:format",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@fontsource-variable/inter": "5.2.8",
    "@types/pg": "8.15.6",
    "capnp-es": "0.0.14",
    "dotenv": "17.2.3",
    "drizzle-kit": "0.31.7",
    "husky": "9.1.7",
    "turbo": "2.6.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "ultracite": "6.3.5",
    "wrangler": "4.76.0"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "infra/*",
    "packages/*"
  ],
  "dependencies": {
    "@t3-oss/env-core": "0.13.10",
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3"
  }
}
